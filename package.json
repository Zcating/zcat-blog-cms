{
  "name": "zcat-blog-cms",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prepare": "husky",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "dev": "pnpm -r run dev",
    "dev:ui": "pnpm -r --filter=ui run dev",
    "dev:doc": "pnpm --filter=doc run dev",
    "dev:backend": "pnpm --filter=backend run dev",
    "dev:frontend": "pnpm --filter=frontend run dev",
    "dev:blog": "pnpm --filter=blog run dev",
    "dev:blog:prod": "pnpm --filter=blog run dev:prod",
    "build": "pnpm -r run build",
    "build:backend": "pnpm --filter=backend run build",
    "build:frontend": "pnpm --filter=frontend run build",
    "build:blog": "pnpm --filter=blog run build",
    "docker:dev": "docker compose -f docker-compose.dev.yaml up -d --build",
    "docker:dev:db": "pnpm run docker:dev cms_pg",
    "docker:dev:backend": "pnpm run docker:dev backend",
    "docker:dev:frontend": "pnpm run docker:dev frontend",
    "docker:dev:blog": "pnpm run docker:dev blog",
    "docker:build": "pnpm run docker:build:backend && pnpm run docker:build:frontend && pnpm run docker:build:blog",
    "docker:build:backend": "tsx ./scripts/docker-push.ts --env-file .env.deploy -y -p backend",
    "docker:build:frontend": "tsx ./scripts/docker-push.ts --env-file .env.deploy -y -p frontend",
    "docker:build:blog": "tsx ./scripts/docker-push.ts --env-file .env.deploy -y -p blog"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.0.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/shelljs": "^0.10.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-check-file": "^3.3.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "node-ssh": "^13.2.1",
    "shelljs": "^0.10.0",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.52.0"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.0.17"
  },
  "engines": {
    "node": ">=22.4.0",
    "pnpm": ">=10.5.1",
    "npm": ">=10.9.2"
  },
  "lint-staged": {
    "apps/backend/**/*.{js,ts}": [
      "pnpm --filter backend exec eslint --fix"
    ],
    "apps/frontend/**/*.{js,ts,tsx}": [
      "pnpm --filter frontend exec eslint --fix"
    ],
    "apps/blog/**/*.{js,ts,tsx}": [
      "pnpm --filter blog exec eslint --fix"
    ],
    "packages/ui/**/*.{js,ts,tsx}": [
      "pnpm --filter @zcat/ui exec eslint --fix"
    ],
    "packages/doc/**/*.{js,ts,tsx}": [
      "pnpm --filter doc exec eslint --fix"
    ]
  }
}