{
  "extends": "../../tsconfig.json",
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "baseUrl": ".",
    "paths": {
      "@blog/common": ["./app/common"],
      "@blog/common/*": ["./app/common/*"],
      "@blog/features": ["./app/features"],
      "@blog/features/*": ["./app/features/*"],
      "@blog/routes": ["./app/routes"],
      "@blog/routes/*": ["./app/routes/*"],
      "@blog/apis": ["./app/apis"],
      "@blog/apis/*": ["./app/apis/*"],
      "@root": ["./app/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "references": [
    {
      "path": "../../packages/ui"
    }
  ]
}
